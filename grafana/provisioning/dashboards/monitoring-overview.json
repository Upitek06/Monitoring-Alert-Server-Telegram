global:
  scrape_interval: 15s

scrape_configs:
  - job_name: 'node-exporter'
    static_configs:
      - targets: ['node-exporter:9100']

  - job_name: 'vmalert'
    static_configs:
      - targets: ['vmalert:8880']

  - job_name: 'alertmanager'
    static_configs:
      - targets: ['alertmanager:9093']
